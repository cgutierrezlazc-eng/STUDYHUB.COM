{
  "name": "conniku",
  "version": "1.0.0",
  "description": "Plataforma universitaria todo-en-uno",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron dist/main/main.js",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron dist/main/main.js",
    "backend:install": "pip3 install -r backend/requirements.txt",
    "backend:start": "python3 backend/server.py",
    "mobile:build": "vite build && npx cap sync",
    "mobile:android": "vite build && npx cap sync android && npx cap open android",
    "mobile:ios": "vite build && npx cap sync ios && npx cap open ios",
    "mobile:sync": "npx cap sync",
    "mobile:run:android": "npx cap run android",
    "mobile:run:ios": "npx cap run ios",
    "mobile:dev": "vite build --watch & npx cap sync android --watch",
    "build:apk": "bash scripts/trigger-apk-build.sh",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "typecheck": "tsc --noEmit",
    "lint:backend": "python3 -m ruff check backend/",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm run test && python3 -m ruff check backend/"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --no-warn-ignored",
      "prettier --check"
    ],
    "backend/**/*.py": [
      "python3 -m ruff check"
    ]
  },
  "dependencies": {
