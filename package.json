{
  "name": "conniku",
  "version": "1.0.0",
  "description": "AI-powered study assistant for university students",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron dist/main/main.js",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron dist/main/main.js",
    "backend:install": "pip3 install -r backend/requirements.txt",
    "backend:start": "python3 backend/server.py",
    "mobile:build": "vite build && npx cap sync",
    "mobile:android": "vite build && npx cap sync android && npx cap open android",
    "mobile:ios": "vite build && npx cap sync ios && npx cap open ios",
    "mobile:sync": "npx cap sync",
    "mobile:run:android": "npx cap run android",
    "mobile:run:ios": "npx cap run ios",
    "mobile:dev": "vite build --watch & npx cap sync android --watch"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "electron-store": "^8.1.0",
    "html2canvas": "^1.4.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.4",
    "katex": "^0.16.9",
    "lucide-react": "^0.311.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
