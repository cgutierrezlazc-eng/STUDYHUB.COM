# ─── Frontend (Vite) ──────────────────────────────────────
# Backend API URL (leave empty for auto-detect)
VITE_API_URL=https://studyhub-api-bpco.onrender.com

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ─── Backend (Python/FastAPI) ─────────────────────────────
# JWT secret for signing access tokens (REQUIRED in production)
JWT_SECRET=generate-a-strong-random-secret-here

# Owner account password (set to create owner on first boot)
OWNER_PASSWORD=your-secure-owner-password

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://conniku.com,https://www.conniku.com,http://localhost:5173

# Bcrypt rounds for password hashing (default: 12)
BCRYPT_ROUNDS=12

# Email System (Zoho Mail — consolidated through CEO account)
# Future: expand to noreply@, contacto@, ceo@ with separate credentials
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=ceo@conniku.com
SMTP_PASS=your-ceo-zoho-password
SMTP_FROM=ceo@conniku.com
SMTP_REPLY_TO=ceo@conniku.com
CEO_EMAIL=ceo@conniku.com
CONTACT_EMAIL=ceo@conniku.com

# Anthropic API key (for AI features - chat, quizzes, guides, etc.)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Database reset flag (set to 1 only when you need to wipe DB)
FORCE_DB_RESET=0

# Stripe payment integration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_YEARLY=price_your_yearly_price_id
STRIPE_PRICE_MAX_MONTHLY=price_your_max_monthly_price_id
STRIPE_PRICE_MAX_YEARLY=price_your_max_yearly_price_id
FRONTEND_URL=https://conniku.com

# Chile SII (Servicio de Impuestos Internos) — Boleta Electrónica
SII_RUT_EMISOR=12345678-9
SII_CERT_PATH=/path/to/sii-certificate.pfx
SII_API_BASE=https://www4c.sii.cl/bolcoreinternetui/api/

# Search Engine APIs (configure at least one)
GOOGLE_SEARCH_API_KEY=your-google-custom-search-api-key
GOOGLE_SEARCH_CX=your-custom-search-engine-id
BING_SEARCH_API_KEY=your-bing-search-api-key
