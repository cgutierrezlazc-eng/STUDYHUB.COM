## ─── Frontend (Vite) ──────────────────────────────────────────────────────────
## Variables para el frontend. En producción se configuran en Vercel.
## En desarrollo local, copiar este archivo a .env.local (NO commitear .env.local)

# Backend API URL (dejar vacío para auto-detect en localhost)
VITE_API_URL=https://studyhub-api-bpco.onrender.com

# Google OAuth Client ID — parte pública, va también en Vite
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

## ─── Deploy y entorno ──────────────────────────────────────────────────────────
## Variables críticas de despliegue. OBLIGATORIAS en producción (Render).

# JWT secret para firmar access tokens — generar con: openssl rand -hex 32
# REQUERIDA. Sin esta key el backend no levanta en producción.
JWT_SECRET=generate-a-strong-random-secret-here

# Contraseña del usuario owner (se usa solo en primer arranque para seed)
OWNER_PASSWORD=your-secure-owner-password

# Email del admin principal — usado en migrations.py para primer seed
# Ejemplo: admin@conniku.com
ADMIN_EMAIL=admin@conniku.com

# Setup key para el endpoint /admin/setup (protege la inicialización)
# Generar con: openssl rand -hex 16
SETUP_KEY=generate-a-setup-key-here

# URL de la base de datos PostgreSQL (Supabase en producción)
# Formato: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/conniku_db

# Entorno actual: "production", "staging", o "development"
# Usado en middleware.py para activar HTTPS-only cookies y CORS estricto
ENVIRONMENT=development

# Render detecta automáticamente con esta var que corre en su plataforma
# En Render se configura como RENDER=true automáticamente
RENDER=false

# Orígenes CORS permitidos (separados por coma, sin espacios)
CORS_ORIGINS=https://conniku.com,https://www.conniku.com,http://localhost:5173

# URL pública del frontend — usada en emails transaccionales y links
FRONTEND_URL=https://conniku.com

# URL pública del backend — usada en referencias internas y health checks
BACKEND_URL=https://studyhub-api-bpco.onrender.com

# Puerto en que corre el backend (Render asigna el suyo; 8899 es local)
PORT=8899

# Rondas bcrypt para hashing de contraseñas (default: 12)
BCRYPT_ROUNDS=12

# Reset de base de datos (poner en 1 SOLO en desarrollo para wipear DB)
FORCE_DB_RESET=0

# Ruta del disco persistente en Render (asignado automáticamente por Render)
RENDER_DISK_MOUNT_PATH=/data

## ─── SMTP Zoho Mail ────────────────────────────────────────────────────────────
## Tres cuentas Zoho para diferentes propósitos.
## En producción, SMTP_PASS se puede usar como fallback compartido
## o configurar contraseñas individuales por cuenta.

# Servidor SMTP Zoho
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587

# Contraseña fallback genérica (si no se configuran las individuales)
SMTP_PASS=your-zoho-shared-password

# Cuenta noreply@conniku.com — emails automáticos, verificaciones, notificaciones
NOREPLY_EMAIL=noreply@conniku.com
SMTP_PASS_NOREPLY=your-zoho-noreply-password

# Cuenta contacto@conniku.com — formularios de contacto, soporte
CONTACT_EMAIL=contacto@conniku.com
SMTP_PASS_CONTACTO=your-zoho-contacto-password

# Cuenta ceo@conniku.com — documentos importantes, facturas, IMAP
CEO_EMAIL=ceo@conniku.com
SMTP_PASS_CEO=your-zoho-ceo-password

## ─── OAuth Google ──────────────────────────────────────────────────────────────
## Credenciales del proyecto en Google Cloud Console.
## Configurar en: https://console.cloud.google.com/apis/credentials

# Client ID (también en VITE_GOOGLE_CLIENT_ID para el frontend)
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Client Secret (solo backend — NUNCA exponer en frontend)
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

## ─── Pagos — MercadoPago ───────────────────────────────────────────────────────
## Credenciales de MercadoPago para el mercado chileno/latinoamericano.
## Obtener en: https://www.mercadopago.cl/developers/es/docs

# Access token de producción (comienza con APP_USR-)
MP_ACCESS_TOKEN=APP_USR-your-mp-access-token-here

# Public key de producción (comienza con APP_USR-)
MP_PUBLIC_KEY=APP_USR-your-mp-public-key-here

# Secreto para validar firma de webhooks de MercadoPago
MP_WEBHOOK_SECRET=your-mp-webhook-secret-here

## ─── Pagos — PayPal ────────────────────────────────────────────────────────────
## Credenciales de PayPal para usuarios internacionales.
## Obtener en: https://developer.paypal.com/dashboard/applications

# Client ID de la aplicación PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id-here

# Client Secret de la aplicación PayPal (solo backend)
PAYPAL_CLIENT_SECRET=your-paypal-client-secret-here

# Webhook ID para validar firmas de eventos PayPal
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id-here

# Modo de operación: "live" o "sandbox"
PAYPAL_MODE=live

## ─── Pagos — Stripe ────────────────────────────────────────────────────────────
## Stripe para tarjetas internacionales (mercado global).
## Obtener en: https://dashboard.stripe.com/apikeys

# Secret key (comienza con sk_live_ en producción)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Secreto para validar webhooks de Stripe (comienza con whsec_)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Price ID del plan mensual Conniku Pro
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id

# Price ID del plan anual Conniku Pro
STRIPE_PRICE_YEARLY=price_your_yearly_price_id

# [DEPRECATED] Tier MAX eliminado 2026-04. Solo existen free + Conniku Pro.
# [DEPRECATED] Esta variable NO tiene efecto. Eliminar en bloque de limpieza post-launch.
STRIPE_PRICE_MAX_MONTHLY=

## ─── Push Notifications — VAPID ────────────────────────────────────────────────
## Claves VAPID para Web Push Notifications (PWA).
## Generar con: npx web-push generate-vapid-keys

# Clave pública VAPID (se envía al navegador)
VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Clave privada VAPID (solo backend — NUNCA exponer)
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# Email del administrador para identificación VAPID (formato: mailto:)
VAPID_EMAIL=mailto:noreply@conniku.com

## ─── IA y procesamiento ────────────────────────────────────────────────────────
## APIs de modelos de lenguaje usadas por el backend.

# Anthropic API key — REQUERIDA (Konni, Athena, chat, quizzes, guías, soporte)
# Sin esta key: GET /workspaces/{id}/athena/ping retorna claude_available:false
# Formato: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# OpenAI API key — fallback opcional para embeddings u otras tareas específicas
OPENAI_API_KEY=sk-your-openai-key-here

## ─── IMAP (recepción de email) ─────────────────────────────────────────────────
## Usado para recibir documentos por email (email_doc_routes.py).
## Cuenta: ceo@conniku.com via Zoho IMAP.

# Servidor IMAP Zoho
IMAP_HOST=imap.zoho.com

# Puerto IMAP (993 = TLS, 143 = STARTTLS)
IMAP_PORT=993

## ─── SII — Boleta Electrónica ──────────────────────────────────────────────────
## Chile SII para emisión de boletas electrónicas.
## Datos de producción de Conniku SpA — RUT 78.395.702-7

# RUT del emisor (Conniku SpA)
SII_RUT_EMISOR=78.395.702-7

# Ruta al certificado digital .pfx para firmar documentos SII
SII_CERT_PATH=/path/to/sii-certificate.pfx

# Base URL de la API del SII
SII_API_BASE=https://www4c.sii.cl/bolcoreinternetui/api/

## ─── Motores de búsqueda ───────────────────────────────────────────────────────
## Para la Biblioteca de Conniku. Configurar al menos uno.

# Google Custom Search API key
GOOGLE_SEARCH_API_KEY=your-google-custom-search-api-key

# Google Custom Search Engine ID (cx)
GOOGLE_SEARCH_CX=your-custom-search-engine-id

# Bing Search API key (alternativa a Google)
BING_SEARCH_API_KEY=your-bing-search-api-key

## ─── Feature Flags ─────────────────────────────────────────────────────────────
## Controlan comportamiento de features específicas sin redeploy.
## Cambiar en el panel de Render sin necesidad de nuevo deploy.

# Activa el gate legal (re-aceptación obligatoria si hay nueva versión de T&C)
# Valores: "true" | "false" | "1" | "0"
# En producción: activar a "true" DESPUÉS de merge del PR legal v3.2
LEGAL_GATE_ENFORCE=false

# Habilita registro público de nuevos usuarios
# Valores: "true" | "false"
# En producción: "true" cuando la plataforma esté lista para usuarios reales
PUBLIC_REGISTRATION_ENABLED=false
