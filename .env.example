# ─── Frontend (Vite) ──────────────────────────────────────
# Backend API URL (leave empty for auto-detect)
VITE_API_URL=https://studyhub-api-bpco.onrender.com

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ─── Backend (Python/FastAPI) ─────────────────────────────
# JWT secret for signing access tokens (REQUIRED in production)
JWT_SECRET=generate-a-strong-random-secret-here

# Owner account password (set to create owner on first boot)
OWNER_PASSWORD=your-secure-owner-password

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://conniku.com,https://www.conniku.com,http://localhost:5173

# Bcrypt rounds for password hashing (default: 12)
BCRYPT_ROUNDS=12

# SMTP configuration for email notifications
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=noreply@conniku.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@conniku.com

# Database reset flag (set to 1 only when you need to wipe DB)
FORCE_DB_RESET=0
