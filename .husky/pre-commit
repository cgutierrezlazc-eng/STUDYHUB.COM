#
# pre-commit hook - Conniku
# Compatible con Husky v9+
# 
# Se ejecuta automáticamente antes de cada git commit.
# Verifica tres cosas antes de permitir el commit:
#
#   1. Lint-staged: calidad de código en archivos modificados
#   2. Archivos protegidos: que no se modifiquen archivos frozen
#      sin la bandera UNFREEZE_ACTIVE
#   3. Sintaxis de archivos críticos: JSON, bash, yaml
#
# Si alguna verificación falla, el commit se bloquea.
# Para casos de emergencia, puede usarse: git commit --no-verify
# (solo para emergencias documentadas, nunca como hábito)
#

# Colores para mensajes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

# Contador de errores encontrados
ERRORS=0

echo ""
echo "${BOLD}════════════════════════════════════════════════════════════${NC}"
echo "${BOLD}  Pre-commit - Verificando antes de commitear              ${NC}"
echo "${BOLD}════════════════════════════════════════════════════════════${NC}"

# ============================================================
# VERIFICACIÓN 1: lint-staged
# ============================================================
echo ""
echo "${BOLD}[1/3] Lint-staged (linters sobre archivos modificados)${NC}"

if npx lint-staged; then
    echo "${GREEN}    OK: lint-staged pasó${NC}"
else
    echo "${RED}    FALLO: lint-staged detectó problemas${NC}"
    echo ""
    echo "${YELLOW}    Qué pasó: los archivos que vas a commitear tienen${NC}"
    echo "${YELLOW}    errores de formato o lint que deben corregirse${NC}"
    echo "${YELLOW}    antes del commit.${NC}"
    echo ""
    echo "${YELLOW}    Qué hacer:${NC}"
    echo "${YELLOW}      - Revisa los errores reportados arriba${NC}"
    echo "${YELLOW}      - Corrige manualmente o usa autofix si disponible${NC}"
    echo "${YELLOW}      - Vuelve a agregar con: git add <archivos>${NC}"
    echo "${YELLOW}      - Reintenta: git commit${NC}"
    ERRORS=$((ERRORS + 1))
fi

# ============================================================
# VERIFICACIÓN 2: archivos frozen
# ============================================================
echo ""
echo "${BOLD}[2/3] Protección de archivos frozen${NC}"

# Verificar si el script check-frozen.sh existe
if [ -x ".claude/scripts/check-frozen.sh" ]; then
    # Obtener lista de archivos staged (que van en este commit)
    STAGED_FILES=$(git diff --cached --name-only)
    
    if [ -z "$STAGED_FILES" ]; then
        echo "${GREEN}    OK: no hay archivos staged${NC}"
    else
        # Verificar si UNFREEZE_ACTIVE está presente
        if [ -f ".claude/UNFREEZE_ACTIVE" ]; then
            echo "${YELLOW}    ADVERTENCIA: UNFREEZE_ACTIVE está activo${NC}"
            echo "${YELLOW}    La protección de archivos frozen está DESACTIVADA.${NC}"
            echo "${YELLOW}    Asegúrate de desactivarla después del commit con:${NC}"
            echo "${YELLOW}      rm .claude/UNFREEZE_ACTIVE${NC}"
            echo "${GREEN}    (commit permitido)${NC}"
        else
            # Chequear cada archivo contra la lista de frozen
            FROZEN_VIOLATIONS=""
            for FILE in $STAGED_FILES; do
                if bash .claude/scripts/check-frozen.sh "$FILE" > /dev/null 2>&1; then
                    continue
                else
                    FROZEN_VIOLATIONS="$FROZEN_VIOLATIONS $FILE"
                fi
            done
            
            if [ -z "$FROZEN_VIOLATIONS" ]; then
                echo "${GREEN}    OK: ningún archivo frozen modificado${NC}"
            else
                echo "${RED}    FALLO: estás intentando modificar archivos frozen${NC}"
                echo ""
                echo "${YELLOW}    Archivos frozen en este commit:${NC}"
                for F in $FROZEN_VIOLATIONS; do
                    echo "${YELLOW}      - $F${NC}"
                done
                echo ""
                echo "${YELLOW}    Qué hacer:${NC}"
                echo "${YELLOW}      - Si la modificación es intencional y justificada:${NC}"
                echo "${YELLOW}        1. Activa flag: touch .claude/UNFREEZE_ACTIVE${NC}"
                echo "${YELLOW}        2. Reintenta el commit${NC}"
                echo "${YELLOW}        3. Desactiva flag después:${NC}"
                echo "${YELLOW}           rm .claude/UNFREEZE_ACTIVE${NC}"
                echo "${YELLOW}      - Si NO era intencional:${NC}"
                echo "${YELLOW}        Deshaz los cambios a esos archivos${NC}"
                echo "${YELLOW}        git checkout HEAD -- <archivos>${NC}"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    fi
else
    echo "${YELLOW}    ADVERTENCIA: check-frozen.sh no encontrado o no ejecutable${NC}"
    echo "${YELLOW}    La protección de archivos frozen no se verificó.${NC}"
    echo "${YELLOW}    Considera ejecutar: chmod +x .claude/scripts/check-frozen.sh${NC}"
fi

# ============================================================
# VERIFICACIÓN 3: sintaxis de archivos críticos
# ============================================================
echo ""
echo "${BOLD}[3/3] Sintaxis de archivos críticos (JSON, bash, yaml)${NC}"

SYNTAX_ERRORS=0
STAGED_CRITICAL=$(git diff --cached --name-only | grep -E '\.(json|sh|yml|yaml)$')

if [ -z "$STAGED_CRITICAL" ]; then
    echo "${GREEN}    OK: ningún archivo crítico en este commit${NC}"
else
    for FILE in $STAGED_CRITICAL; do
        # Si el archivo fue eliminado, saltar
        if [ ! -f "$FILE" ]; then
            continue
        fi
        
        case "$FILE" in
            *.json)
                if ! python3 -c "import json; json.load(open('$FILE'))" 2>/dev/null; then
                    echo "${RED}    FALLO: JSON inválido en $FILE${NC}"
                    SYNTAX_ERRORS=$((SYNTAX_ERRORS + 1))
                fi
                ;;
            *.sh)
                if ! bash -n "$FILE" 2>/dev/null; then
                    echo "${RED}    FALLO: error de sintaxis bash en $FILE${NC}"
                    SYNTAX_ERRORS=$((SYNTAX_ERRORS + 1))
                fi
                ;;
            *.yml|*.yaml)
                if command -v yamllint > /dev/null 2>&1; then
                    if ! yamllint -d relaxed "$FILE" > /dev/null 2>&1; then
                        echo "${YELLOW}    ADVERTENCIA: problemas de yaml en $FILE${NC}"
                    fi
                fi
                ;;
        esac
    done
    
    if [ $SYNTAX_ERRORS -eq 0 ]; then
        echo "${GREEN}    OK: todos los archivos críticos tienen sintaxis válida${NC}"
    else
        echo ""
        echo "${YELLOW}    Qué hacer: corrige los errores de sintaxis antes del commit${NC}"
        ERRORS=$((ERRORS + SYNTAX_ERRORS))
    fi
fi

# ============================================================
# Resultado final
# ============================================================
echo ""
echo "${BOLD}════════════════════════════════════════════════════════════${NC}"

if [ $ERRORS -eq 0 ]; then
    echo "${GREEN}${BOLD}  Pre-commit: TODAS LAS VERIFICACIONES PASARON${NC}"
    echo "${BOLD}════════════════════════════════════════════════════════════${NC}"
    echo ""
    exit 0
else
    echo "${RED}${BOLD}  Pre-commit: COMMIT BLOQUEADO ($ERRORS errores)${NC}"
    echo "${BOLD}════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo "${YELLOW}Escape de emergencia (solo para casos documentados):${NC}"
    echo "${YELLOW}  git commit --no-verify -m \"mensaje\"${NC}"
    echo "${YELLOW}  (usar solo si tienes razón clara documentada)${NC}"
    echo ""
    exit 1
fi
